# ===========================================
# FamilyTree v2 — Environment Variables
# ===========================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
# ===========================================

# ---------- PostgreSQL ----------
POSTGRES_USER=familytree
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=familytree

# ---------- Backend (FastAPI) ----------
DATABASE_URL=postgresql://familytree:change-me-in-production@postgres:5432/familytree
JWT_SECRET=change-me-to-a-strong-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ---------- CORS ----------
# Список разрешённых origin через запятую
CORS_ORIGINS=http://localhost:3000

# ---------- Frontend (Next.js) ----------
# URL backend API для server-side рендеринга
NEXT_PUBLIC_API_URL=http://localhost:8000
